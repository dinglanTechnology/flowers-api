# ===== 服务 =====
PORT=3000
NODE_ENV=development

# ===== 数据库 / Redis =====
DATABASE_URL=postgresql://flower:flower@localhost:5432/flower?schema=public
REDIS_URL=redis://localhost:6379

# ===== JWT =====
JWT_SECRET=change_me_in_production   # 生产必须换：openssl rand -base64 48
JWT_ACCESS_EXPIRES_IN=30d            # access 有效期；客户端未做刷新前 = 强制重登间隔
JWT_REFRESH_EXPIRES_IN=90d           # refresh 有效期（存于 Redis），待客户端接入刷新后生效

# ===== Web 端 CORS + httpOnly Cookie =====
# CORS 已全放开（反射任意 origin + 允许携带凭证），无需任何配置
# CORS_ORIGINS=                      # 已废弃，不再读取
COOKIE_DOMAIN=                       # 跨子域共享设 .example.com；留空=host-only（推荐，localhost 也能用）
COOKIE_SAMESITE=none                 # 默认 none：跨站（localhost 页面 → 远程 API）也能带 Cookie；同站部署可改 lax 收紧
COOKIE_SECURE=                       # 默认 true（SameSite=None 必须）；Chrome/Firefox 对 http://localhost 同样放行 Secure Cookie

# ===== 微信小程序 =====
WX_APPID=
WX_SECRET=

# ===== 阿里云短信（Web 手机号验证码登录）=====
# 不填则发码走开发降级：不真发短信，验证码打印到服务日志
SMS_ACCESS_KEY_ID=
SMS_ACCESS_KEY_SECRET=
SMS_ENDPOINT=dysmsapi.aliyuncs.com   # 一般无需改
SMS_SIGN_NAME=                       # 短信签名
SMS_TEMPLATE_CODE=                   # 验证码模板 CODE，模板变量名须为 code

# ===== AI 中转站（主/备双 provider 故障转移；两家协议不同） =====
AI_PROVIDER=mock                 # relay | mock（本地用 mock 免外部依赖；启用中转站改 relay）

# 主用：Atlas Cloud（自研图像接口，非 OpenAI 兼容）
AI_ATLAS_BASE_URL=https://api.atlascloud.ai/api/v1
AI_ATLAS_API_KEY=
# 备用：TokenLab（OpenAI 兼容；主用失败时自动切换）—— 待验证其图像接口
AI_TOKENLAB_BASE_URL=https://api.tokenlab.sh/v1
AI_TOKENLAB_API_KEY=

# 模型 ID：分平台配置（各有代码默认值，一般不用填；要改就取消注释覆盖）。
# 注意：image2=出图(图生图)，cutout=抠图(透明底)；共用变量 AI_IMAGE2_MODEL/AI_CUTOUT_MODEL 已废弃不再读取。
# 主用 Atlas（模型名带 action 后缀）：
# AI_ATLAS_IMAGE2_MODEL=openai/gpt-image-2/edit
# AI_ATLAS_CUTOUT_MODEL=youchuan/v8.1/remove-background   # 专用去背，出真透明 PNG（生图/edit 模型不出透明）
# 备用 TokenLab（OpenAI 兼容，裸模型名）：
# AI_TOKENLAB_IMAGE2_MODEL=gpt-image-2
# AI_TOKENLAB_CUTOUT_MODEL=image-background-remover

# 兼容旧配置：未填 AI_ATLAS_* 时回退用下面这对作为主用 baseUrl/key（可忽略）
# AI_BASE_URL=
# AI_API_KEY=

# ===== 存储 =====
STORAGE_PROVIDER=minio           # oss | minio
OSS_REGION=oss-cn-hangzhou
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_ENDPOINT=                    # minio 时填 http://localhost:9000
OSS_CDN_BASE=                    # 可选，CDN/自定义域名；生产已绑 https://flower-prod.zhilingtech.com
