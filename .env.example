# ===== 服务 =====
PORT=3000
NODE_ENV=development

# ===== 数据库 / Redis =====
DATABASE_URL=postgresql://flower:flower@localhost:5432/flower?schema=public
REDIS_URL=redis://localhost:6379

# ===== JWT =====
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=30d

# ===== 微信小程序 =====
WX_APPID=
WX_SECRET=

# ===== AI 中转站（OpenAI 兼容） =====
AI_PROVIDER=mock                 # relay | mock（本地用 mock 免外部依赖）
AI_BASE_URL=https://your-relay.example.com/v1
AI_API_KEY=
AI_IMAGE2_MODEL=gpt-image-1      # 按中转站支持的模型填写
AI_CUTOUT_MODEL=                 # 抠图模型/服务；若单独接则另配

# ===== 存储 =====
STORAGE_PROVIDER=minio           # oss | minio
OSS_REGION=oss-cn-hangzhou
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_ENDPOINT=                    # minio 时填 http://localhost:9000
OSS_CDN_BASE=                    # 可选，CDN 域名
