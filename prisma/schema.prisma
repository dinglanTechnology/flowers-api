// 「插了个花」业务后端数据模型
// 详见 docs/architecture.md §7

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// 用户：微信 openid 或 Web 手机号建号
/// openid 可空（Web 用户无 openid，Postgres unique 允许多个 NULL 并存）
/// phone 唯一，作为跨端统一身份键（同号 Web 登录并入已有微信账号）
model User {
  id        String   @id @default(cuid())
  openid    String?  @unique
  unionid   String?
  phone     String?  @unique
  loginType String   @default("wechat") // wechat | phone，标识建号来源
  nickname  String   @default("")
  avatarId  String   @default("lotus")
  avatarUrl String?
  works     Work[]
  posts     PlazaPost[]
  materials CustomMaterial[]
  aiTasks   AiTask[]
  likes     PlazaLike[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// 作品：插花快照 + 日历聚合
model Work {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id])
  title        String      @default("今日花事")
  theme        String      @default("night")
  vaseId       String
  arrangement  Json // { items[], theme, vaseId, ... } 插花数据快照
  thumbnailUrl String?
  dateKey      String // "2026-07-08"，按天聚合用
  posts        PlazaPost[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([userId, dateKey])
  @@index([userId, createdAt])
}

/// 广场作品（UGC，含内容审核状态）
model PlazaPost {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  authorName   String // 冗余快照，改名不影响历史
  title        String
  theme        String
  arrangement  Json // 支持"点开继续编辑"
  thumbnailUrl String?
  likeCount    Int         @default(0) // 冗余计数，随 PlazaLike 增删维护
  viewCount    Int         @default(0) // 冗余计数，随浏览上报去重后递增
  workId       String? // 来源作品；作品删除时级联撤回本帖
  work         Work?    @relation(fields: [workId], references: [id], onDelete: Cascade)
  likes        PlazaLike[]
  auditStatus  String      @default("pending") // pending | approved | rejected
  createdAt    DateTime    @default(now())

  @@index([auditStatus, createdAt])
  @@index([workId])
}

/// 点赞记录（userId + postId 唯一，防重复赞、支持取消）
model PlazaLike {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  postId    String
  post      PlazaPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@unique([userId, postId])
  @@index([postId])
}

/// 默认花材（官方内置素材，全局共享，无 owner）。imageUrl 指向 OSS 透明底 PNG。
model Material {
  id        String   @id // 与素材 id / OSS 文件名一致，如 mat-rose
  name      String
  category  String // flower | greenery | line | vase
  kind      String
  colors    String[] // 主色，前端矢量渲染/回退用
  shape     String? // 花器形状
  imageUrl  String? // OSS 透明底 PNG 地址；内置素材走矢量时可为空
  styles    Json? // 多样式预设数组 [{styleOption,name,morph,lengthScale,colors}]；单样式素材(花器/自定义)为 null
  sortOrder Int      @default(0) // 目录展示顺序
  active    Boolean  @default(true) // 下架开关，无需删除数据
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category, sortOrder])
}

/// 自定义花材（AI 抠图产物）
model CustomMaterial {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  name           String
  category       String // flower | greenery | line | vase
  baseMaterialId String
  baseKind       String?
  imageUrl       String // 透明底成品
  sourceImageUrl String? // 上传原图
  createdAt      DateTime @default(now())

  @@index([userId, createdAt])
}

/// AI 异步任务（image2 / cutout）
model AiTask {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  type           String // image2 | cutout
  status         String   @default("pending") // pending | running | succeeded | failed
  progress       Int      @default(0)
  prompt         String?
  inputImageUrl  String?
  resultUrl      String?
  thumbUrl       String? // 缩略图（480px webp），列表/封面场景代替原图
  error          String?
  workId         String? // 关联作品（不加 FK，作品删除后任务保留）；NULL=未保存草稿
  meta           Json? // size / baseMaterialId / category 等
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([userId, workId, createdAt])
}
